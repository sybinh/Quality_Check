# RQ1/ClearQuest Authentication
RQ1_USER=your_username_here
# Note: Password is NOT stored in .env file for security!
# You will be prompted for password when running the tool.

# Project IDs: RQ1 numbers of Release/Projects to validate
# Format: Comma-separated RQ1 numbers (e.g., RQONE00001940,RQONE00002345)
# Find in RQ1: Go to Release details ? copy RQ1 number
# Example: RQONE00001940
RQ1_PROJECT_IDS=RQONE00001940
